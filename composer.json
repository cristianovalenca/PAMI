{
  "name": "cristianovalenca/pami",
  "type": "library",
  "description": "Asterisk Manager Interface (AMI) client for PHP, event driven, object oriented",
  "keywords": ["asterisk","ami","client","telephony","voip","event","action","manager","monitor"],
  "homepage": "http://marcelog.github.com/PAMI",
  "license": "Apache-2.0",
  "authors": [
    {
      "name": "Marcelo Gornstein",
      "email": "marcelog@gmail.com",
      "homepage": "http://marcelog.github.com/",
      "role": "Developer"
    }
  ],
  "autoload": {
    "psr-4": {
      "PAMI\\": "src/PAMI"
    }
  },
  "require": {
    "php": ">=7.1",
    "psr/log": "^1.0 || ^2.0 || ^3.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6",
    "monolog/monolog": "^2.9",
    "squizlabs/php_codesniffer": "^3.9"
  },
  "scripts": {
    "test": "phpunit",
    "cs": "phpcs --standard=PSR12 src"
  },
  "config": {
    "sort-packages": true
  }
}
